OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_APP_NAME=Quorum
OPENROUTER_SITE_URL=http://localhost:3000
NOUS_API_KEY=your_nous_api_key_here

# === Auth (no external services) ===
